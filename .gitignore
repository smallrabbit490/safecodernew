# Keep compact reports and curated experiment outputs, but exclude huge local work dirs
baseline/baseline_test_work/
baseline/**/venv/
baseline/**/.venv/
baseline/**/*.zip
baseline/**/__pycache__/

# External cloned repos are reference material and can be re-downloaded
external_repos/

# Local API usage notes may contain private provider examples or screenshots.
质朴api使用/

# Runtime logs and transient experiment directories
logs/
Temp/
tmp/
*.tmp

# Large third-party baseline unpacked archives and logs.
# The public snapshot keeps our analysis docs and compact experience-transfer
# experiment, not full downloaded baseline packages.
baseline/codesecevalDatasetAndMethod/
baseline/SeCodePLT-main/
baseline/cweval/
baseline/**/*.log
baseline/**/*.pdf

# Keep compact experiment code and selected reports, but exclude generated run
# dumps unless they are the curated first-migration summaries.
baseline/experience_transfer_experiment/out/**
!baseline/experience_transfer_experiment/out/
!baseline/experience_transfer_experiment/out/coset_eagle_self_evolve_30/
!baseline/experience_transfer_experiment/out/coset_eagle_self_evolve_30/report.md
!baseline/experience_transfer_experiment/out/coset_eagle_self_evolve_30/failure_taxonomy.json

# Translation work: keep reports, manual fixes, and compact metadata; exclude
# bulky generated batches by default.
translation_work/outputs/**
!translation_work/outputs/
translation_work/manual_fix/**/*.exe
translation_work/manual_fix/**/*.out
translation_work/manual_fix/**/*.o

# Candidate architecture/method-matrix experiments are exploration artifacts.
# Keep final reports only when explicitly moved into a stable release folder.
translation_work/architecture_experiments/
translation_work/manual_fix/manual_candidates_*
