*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz

# Local downloaded runtimes, caches, sandboxes, and temporary execution outputs
translation_work/cache/
translation_work/downloads/
translation_work/sandbox/
translation_work/temp/
translation_work/logs/
translation_work/scripts/
